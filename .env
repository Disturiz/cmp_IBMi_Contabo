# ==========================
# IBM i / PUB400
# ==========================
IBMI_HOST=pub400.com
IBMI_USER=GLEARN21
IBMI_PASSWORD=David$64
IBMI_LIBRARY=GLEARN211
IBMI_TABLE=VENTAPF

# Ruta local al driver JDBC de IBM i
JT400_JAR=./drivers/jt400.jar

# URL JDBC
IBMI_JDBC_URL=jdbc:as400://pub400.com;naming=system;errors=full;prompt=false;translate binary=false

# Mapeo de columnas de negocio (ajústalas a tu tabla real)
IBMI_CLIENT_COLUMN=CLIENTE
IBMI_PRODUCT_COLUMN=PRODUCTO
IBMI_DEFAULT_ORDER_COLUMN=

# ==========================
# MCP Server
# ==========================
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_TRANSPORT=sse
LOG_LEVEL=INFO
